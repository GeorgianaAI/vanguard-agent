# 🧠 AI Engine. Primary Satellite Brain (Anthropic Claude 4.6)
# Powers the core Agentic Reasoning, Tool-Calling, and Reconnaissance Logic.
ANTHROPIC_API_KEY=
ANTHROPIC_AUDITOR_MODEL=
ANTHROPIC_SCOUT_MODEL=

# 📡 Reconnaissance Intelligence (Tavily AI)
# The search engine built for AI Agents (Agentic Scout)
# Provides real-time, AI-optimized web search for live threat intelligence.
TAVILY_API_KEY=

# ⚖️ LLM-as-Judge (OpenAI GPT-4o)
# Cross-provider confidence calibration judge for the Governance Ledger (near-term).
# See docs/TECHNICAL_ADVISORY.md §12 for rationale.
OPENAI_API_KEY=

# ☁️ Persistent Vector Vault (Upstash Vector)
# Stores reconnaissance results and CVE data for semantic retrieval.
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# 🛡️ Economic Shield & Mission Persistence (Upstash Redis)
# We use the same Redis DB for both State and Throttling 
# Persists the LangGraph "Checkpoints" (Mission History)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 📊 Telemetry & Observability (LangSmith)
# Enable both flags to ensure LangGraph loops are captured
LANGSMITH_TRACING=true
LANGCHAIN_TRACING_V2=true 
# Account is in EU - EU endpoint (eu-west)
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
# Primary project for Agentic Reasoning loops
LANGSMITH_PROJECT=
# CRITICAL: Ensures the trace completes before the Next.js Edge function shuts down
LANGCHAIN_CALLBACKS_BACKGROUND=false

# 🔬 Optional Red-Team Isolation Mode (advanced testing only)
# REDTEAM_MODE=true
# RED_TEAM_VECTOR_NAMESPACE=redteam-ci-0000000001
# RED_TEAM_THREAD_PREFIX=redteam-ci

# Auth
AUTH_SESSION_SECRET=
AUTH_SESSION_TTL_SECONDS=
AUTH_COOKIE_NAME=
AUTH_OPERATORS_JSON=

# Internal Key - used by Aegis Node
INTERNAL_API_KEY=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=